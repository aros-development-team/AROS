
include $(SRCDIR)/config/aros.cfg

#MM- workbench-devs-networks-lpe32002-i386 : workbench-devs-networks-lpe32002
#MM- workbench-devs-networks-lpe32002-x86_64 : workbench-devs-networks-lpe32002

FILES := handler unit lpe32002_hw

USER_LDFLAGS := -static
USER_CPPFLAGS := \
        -D__OOP_NOLIBBASE__ \
        -D__OOP_NOMETHODBASES__ \
        -D__OOP_NOATTRBASES__
USER_CFLAGS := -std=gnu99

#MM- workbench-devs-networks-lpe32002 : workbench-devs-networks-lpe32002-normal

#MM- workbench-devs-networks-lpe32002-quick : workbench-devs-networks-lpe32002-normal-quick

%build_module mmake=workbench-devs-networks-lpe32002-normal \
    modname=lpe32002 modtype=device \
    files="lpe32002_init $(FILES)" \
    objdir=$(OBJDIR)/normal moduledir=Devs/Networks uselibs="hiddstubs"

