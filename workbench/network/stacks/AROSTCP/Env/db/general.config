#
# AROSTCP configuration file. See documentation for usage.
#
USELOOPBACK=YES
DEBUGSANA=NO
USENS=SECOND
GATEWAY=NO
HOSTNAME=arosbox.arosnet
LOG FILTERFILE=5
GUI PANEL=MUI
OPENGUI=YES
#
# Path to the DHCP client binary.
# Relative paths are resolved from the AROSTCP root directory.
# Default: C/dhclient
#
#DHCLIENT=C/dhclient

